{
  "$description": "Brand theme \"example\" — generated delta over the light theme; accent ramp \"info\". Accent and link steps chosen by contrast to meet WCAG 2.1 AA.",
  "$extends": "light",
  "color": {
    "$type": "color",
    "accent": {
      "default": {
        "$value": "{color.info.700}"
      },
      "hover": {
        "$value": "{color.info.800}"
      },
      "active": {
        "$value": "{color.info.900}"
      },
      "subtle": {
        "$value": "{color.info.50}"
      },
      "onAccent": {
        "$value": "{color.white}"
      }
    },
    "text": {
      "link": {
        "$value": "{color.info.700}"
      }
    },
    "border": {
      "focus": {
        "$value": "{color.info.600}"
      }
    }
  }
}
