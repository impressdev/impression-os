{
  "$description": "Primitive typography values: families, weights, sizes, line-heights, and letter-spacing. Composed into named type styles in semantic/typography.json.",
  "font": {
    "family": {
      "$type": "fontFamily",
      "sans": {
        "$value": ["Inter", "system-ui", "-apple-system", "Segoe UI", "Roboto", "Helvetica Neue", "Arial", "sans-serif"],
        "$description": "Default UI and body typeface."
      },
      "serif": {
        "$value": ["Source Serif 4", "Georgia", "Cambria", "Times New Roman", "serif"],
        "$description": "Editorial / high-emphasis display alternative."
      },
      "mono": {
        "$value": ["JetBrains Mono", "SFMono-Regular", "Menlo", "Consolas", "Liberation Mono", "monospace"],
        "$description": "Code, technical, and tabular contexts."
      }
    },

    "weight": {
      "$type": "fontWeight",
      "regular":  { "$value": 400 },
      "medium":   { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold":     { "$value": 700 }
    },

    "size": {
      "$description": "Modular type scale, in rem (1rem = 16px root).",
      "$type": "dimension",
      "xs":   { "$value": "0.75rem" },
      "sm":   { "$value": "0.875rem" },
      "base": { "$value": "1rem" },
      "lg":   { "$value": "1.125rem" },
      "xl":   { "$value": "1.25rem" },
      "2xl":  { "$value": "1.5rem" },
      "3xl":  { "$value": "1.875rem" },
      "4xl":  { "$value": "2.25rem" },
      "5xl":  { "$value": "3rem" },
      "6xl":  { "$value": "3.75rem" },
      "7xl":  { "$value": "4.5rem" }
    },

    "line-height": {
      "$description": "Unitless line-height multipliers.",
      "$type": "number",
      "none":    { "$value": 1 },
      "tight":   { "$value": 1.1 },
      "snug":    { "$value": 1.25 },
      "normal":  { "$value": 1.5 },
      "relaxed": { "$value": 1.625 },
      "loose":   { "$value": 2 }
    },

    "letter-spacing": {
      "$description": "Tracking, in em.",
      "$type": "dimension",
      "tighter": { "$value": "-0.05em" },
      "tight":   { "$value": "-0.025em" },
      "normal":  { "$value": "0em" },
      "wide":    { "$value": "0.025em" },
      "wider":   { "$value": "0.05em" }
    }
  }
}
