{
  "$description": "Primitive elevation shadows, expressed as CSS box-shadow strings. Mapped to elevation roles in semantic/shadow.json. Dark themes may override these via themes/ when a lighter, less muddy elevation is required.",
  "shadow": {
    "$type": "shadow",
    "xs":   { "$value": "0 1px 2px 0 rgba(2, 6, 23, 0.05)" },
    "sm":   { "$value": "0 1px 3px 0 rgba(2, 6, 23, 0.10), 0 1px 2px -1px rgba(2, 6, 23, 0.10)" },
    "md":   { "$value": "0 4px 6px -1px rgba(2, 6, 23, 0.10), 0 2px 4px -2px rgba(2, 6, 23, 0.10)" },
    "lg":   { "$value": "0 10px 15px -3px rgba(2, 6, 23, 0.10), 0 4px 6px -4px rgba(2, 6, 23, 0.10)" },
    "xl":   { "$value": "0 20px 25px -5px rgba(2, 6, 23, 0.10), 0 8px 10px -6px rgba(2, 6, 23, 0.10)" },
    "2xl":  { "$value": "0 25px 50px -12px rgba(2, 6, 23, 0.25)" },
    "none": { "$value": "none" }
  }
}
