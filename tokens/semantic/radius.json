{
  "$description": "Semantic corner-radius roles bound to the primitive scale. Theme-independent.",
  "radius": {
    "$type": "dimension",
    "control": { "$value": "{radius.md}",  "$description": "Buttons, inputs, and small interactive controls." },
    "card":    { "$value": "{radius.xl}",  "$description": "Cards, panels, and media containers." },
    "surface": { "$value": "{radius.2xl}", "$description": "Large surfaces and modals." },
    "pill":    { "$value": "{radius.full}", "$description": "Badges, tags, and pill buttons." }
  }
}
