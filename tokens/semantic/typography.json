{
  "$description": "Named type styles: composite tokens that bind family, size, weight, line-height, and tracking into the roles used across the system. Theme-independent. Components reference these, never raw font primitives.",
  "text": {
    "$type": "typography",

    "display": {
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontSize": { "min": "{font.size.4xl}", "max": "{font.size.6xl}" },
        "fontWeight": "{font.weight.bold}",
        "lineHeight": "{font.line-height.tight}",
        "letterSpacing": "{font.letter-spacing.tighter}"
      },
      "$description": "Hero / marquee headline. Font size is fluid: it scales between min (mobile) and max (desktop) via clamp()."
    },

    "h1": {
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontSize": { "min": "{font.size.3xl}", "max": "{font.size.5xl}" },
        "fontWeight": "{font.weight.bold}",
        "lineHeight": "{font.line-height.tight}",
        "letterSpacing": "{font.letter-spacing.tight}"
      }
    },

    "h2": {
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontSize": { "min": "{font.size.2xl}", "max": "{font.size.4xl}" },
        "fontWeight": "{font.weight.semibold}",
        "lineHeight": "{font.line-height.snug}",
        "letterSpacing": "{font.letter-spacing.tight}"
      }
    },

    "h3": {
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontSize": { "min": "{font.size.xl}", "max": "{font.size.3xl}" },
        "fontWeight": "{font.weight.semibold}",
        "lineHeight": "{font.line-height.snug}",
        "letterSpacing": "{font.letter-spacing.normal}"
      }
    },

    "h4": {
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontSize": "{font.size.2xl}",
        "fontWeight": "{font.weight.semibold}",
        "lineHeight": "{font.line-height.snug}",
        "letterSpacing": "{font.letter-spacing.normal}"
      }
    },

    "lead": {
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontSize": "{font.size.xl}",
        "fontWeight": "{font.weight.regular}",
        "lineHeight": "{font.line-height.relaxed}",
        "letterSpacing": "{font.letter-spacing.normal}"
      },
      "$description": "Intro paragraph beneath a heading."
    },

    "body": {
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontSize": "{font.size.base}",
        "fontWeight": "{font.weight.regular}",
        "lineHeight": "{font.line-height.normal}",
        "letterSpacing": "{font.letter-spacing.normal}"
      },
      "$description": "Default running text."
    },

    "small": {
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontSize": "{font.size.sm}",
        "fontWeight": "{font.weight.regular}",
        "lineHeight": "{font.line-height.normal}",
        "letterSpacing": "{font.letter-spacing.normal}"
      }
    },

    "caption": {
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontSize": "{font.size.xs}",
        "fontWeight": "{font.weight.medium}",
        "lineHeight": "{font.line-height.normal}",
        "letterSpacing": "{font.letter-spacing.wide}"
      },
      "$description": "Labels, eyebrows, and metadata."
    },

    "code": {
      "$value": {
        "fontFamily": "{font.family.mono}",
        "fontSize": "{font.size.sm}",
        "fontWeight": "{font.weight.regular}",
        "lineHeight": "{font.line-height.normal}",
        "letterSpacing": "{font.letter-spacing.normal}"
      }
    }
  }
}
